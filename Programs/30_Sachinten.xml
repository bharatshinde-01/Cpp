<?php

$xml = simplexml_load_file("players.xml");   // XML read

echo "<table border=1>";
echo "<tr><th>Name</th><th>Runs</th><th>Wickets</th><th>Matches</th></tr>";

foreach($xml->player as $p)
{
    if($p->runs > 1200 && $p->wickets >= 50)   // condition check
    {
        echo "<tr>";
        echo "<td>".$p->name."</td>";
        echo "<td>".$p->runs."</td>";
        echo "<td>".$p->wickets."</td>";
        echo "<td>".$p->matches."</td>";
        echo "</tr>";
    }
}

echo "</table>";

